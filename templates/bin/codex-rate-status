#!/usr/bin/env python3
"""Print a short Codex rate-limit summary for tmux status bar.

This uses the experimental Codex CLI app-server JSON-RPC interface.
If the CLI, auth, or RPC format is unavailable, it prints a safe fallback.
"""

from __future__ import annotations

import json
import os
import selectors
import shutil
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

CACHE_TTL_SECONDS = int(os.environ.get("CODEX_COMPANY_RATE_TTL", "60"))
RPC_TIMEOUT_SECONDS = float(os.environ.get("CODEX_COMPANY_RATE_TIMEOUT", "6"))
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "codex-company"
CACHE_FILE = CACHE_DIR / "codex-rate-status.json"
LOCK_FILE = CACHE_DIR / "codex-rate-status.lock"


def fallback(message: str = "Codex: rate unavailable") -> None:
    print(message)


def read_cached() -> str | None:
    try:
        if not CACHE_FILE.exists():
            return None
        payload = json.loads(CACHE_FILE.read_text(encoding="utf-8"))
        text = str(payload.get("text", "")).strip()
        timestamp = float(payload.get("timestamp", 0))
        if text and time.time() - timestamp <= CACHE_TTL_SECONDS:
            return text
    except Exception:
        return None
    return None


def write_cache(text: str) -> None:
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        CACHE_FILE.write_text(
            json.dumps({"text": text, "timestamp": time.time()}, ensure_ascii=False),
            encoding="utf-8",
        )
    except Exception:
        pass


def acquire_lock() -> bool:
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        fd = os.open(str(LOCK_FILE), os.O_CREAT | os.O_EXCL | os.O_WRONLY)
        os.close(fd)
        return True
    except FileExistsError:
        try:
            if time.time() - LOCK_FILE.stat().st_mtime > 30:
                LOCK_FILE.unlink(missing_ok=True)
                return acquire_lock()
        except Exception:
            pass
        return False
    except Exception:
        return False


def release_lock() -> None:
    try:
        LOCK_FILE.unlink(missing_ok=True)
    except Exception:
        pass


def send_json(proc: subprocess.Popen[str], payload: dict[str, Any]) -> None:
    if proc.stdin is None:
        raise RuntimeError("stdin closed")
    proc.stdin.write(json.dumps(payload, ensure_ascii=False) + "\n")
    proc.stdin.flush()


def read_json_response(
    proc: subprocess.Popen[str],
    selector: selectors.BaseSelector,
    expected_id: int,
    timeout: float,
) -> dict[str, Any]:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        remaining = max(0.05, deadline - time.monotonic())
        events = selector.select(remaining)
        if not events:
            continue
        if proc.stdout is None:
            break
        line = proc.stdout.readline()
        if not line:
            continue
        try:
            message = json.loads(line)
        except json.JSONDecodeError:
            continue
        if message.get("id") != expected_id:
            continue
        if "error" in message:
            error = message.get("error") or {}
            raise RuntimeError(str(error.get("message") or error))
        return message
    raise TimeoutError(f"timeout waiting for JSON-RPC id={expected_id}")


def label_window(window: dict[str, Any], fallback_label: str) -> str:
    duration = window.get("windowDurationMins")
    if isinstance(duration, (int, float)):
        minutes = int(duration)
        if 240 <= minutes <= 360:
            return "5h"
        if 9000 <= minutes <= 12000:
            return "week"
        if minutes >= 60 and minutes % 60 == 0:
            return f"{minutes // 60}h"
        return f"{minutes}m"
    return fallback_label


def format_window(window: dict[str, Any] | None, fallback_label: str) -> str | None:
    if not isinstance(window, dict):
        return None
    used_raw = window.get("usedPercent")
    if not isinstance(used_raw, (int, float)):
        return None
    remaining = max(0, min(100, 100 - float(used_raw)))
    label = label_window(window, fallback_label)
    return f"{label} {remaining:.0f}%"


def format_credits(credits: dict[str, Any] | None) -> str | None:
    if not isinstance(credits, dict):
        return None
    if credits.get("unlimited") is True:
        return "credits ∞"
    balance = credits.get("balance")
    if balance is None or str(balance).strip() == "":
        return None
    return f"credits {balance}"


def fetch_status() -> str:
    if shutil.which("codex") is None:
        return "Codex: CLI not found"

    proc: subprocess.Popen[str] | None = None
    try:
        proc = subprocess.Popen(
            ["codex", "-s", "read-only", "-a", "untrusted", "app-server"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            bufsize=1,
        )

        if proc.stdout is None:
            return "Codex: rate unavailable"

        selector = selectors.DefaultSelector()
        selector.register(proc.stdout, selectors.EVENT_READ)

        send_json(
            proc,
            {
                "id": 1,
                "method": "initialize",
                "params": {"clientInfo": {"name": "codex-company", "version": "0.1.0"}},
            },
        )
        read_json_response(proc, selector, 1, RPC_TIMEOUT_SECONDS)
        send_json(proc, {"method": "initialized", "params": {}})

        send_json(proc, {"id": 2, "method": "account/rateLimits/read", "params": {}})
        response = read_json_response(proc, selector, 2, RPC_TIMEOUT_SECONDS)
        result = response.get("result") or {}
        limits = result.get("rateLimits") or {}

        parts = [
            format_window(limits.get("primary"), "5h"),
            format_window(limits.get("secondary"), "week"),
            format_credits(limits.get("credits")),
        ]
        visible_parts = [part for part in parts if part]
        if not visible_parts:
            return "Codex: rate unavailable"
        return "Codex: " + " / ".join(visible_parts)
    except Exception:
        return "Codex: rate unavailable"
    finally:
        if proc is not None:
            try:
                proc.terminate()
            except Exception:
                pass
            try:
                proc.wait(timeout=1)
            except Exception:
                try:
                    proc.kill()
                except Exception:
                    pass


def main() -> int:
    cached = read_cached()
    if cached:
        print(cached)
        return 0

    if not acquire_lock():
        cached = read_cached()
        if cached:
            print(cached)
        else:
            fallback("Codex: rate refreshing")
        return 0

    try:
        text = fetch_status()
        write_cache(text)
        print(text)
    finally:
        release_lock()
    return 0


if __name__ == "__main__":
    sys.exit(main())
